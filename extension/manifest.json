{
  "manifest_version": 3,
  "name": "SEO Agent Deep Analyst",
  "version": "1.0",
  "description": "Analyzes the current page applying deep SEO principles and provides actionable feedback.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://seo-writing-agent.onrender.com/*"
  ]
}
